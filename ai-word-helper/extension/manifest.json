{
    "manifest_version": 3,
    "name": "AI Word Helper",
    "version": "0.2.0",
    "description": "Translate clicked words in context on web pages.",
    "permissions": [],
    "host_permissions": [
        "<all_urls>",
        "http://localhost:3000/*"
    ],
    "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "js": ["content.js"],
            "css": ["styles.css"],
            "run_at": "document_idle"
        }
    ],
    "action": {
        "default_title": "AI Word Helper"
    }
}